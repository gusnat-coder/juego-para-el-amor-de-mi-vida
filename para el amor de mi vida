   script.js
================================ */

// Frases que aparecerán al azar
const frases = [
    "No importa la distancia... siempre encontraré el camino hacia ti. ❤️",
    "Hoy te extraño un poquito más. 🌹",
    "Cada día es un paso menos para volver a verte. ✨",
    "Siempre voy a elegirte. ❤️",
    "Quiero verte para vivir los mejores días de mi vida contigo. 💖",
    "Gracias por creer en nosotros. 🌸",
    "La distancia nunca podrá con lo que siento por ti. ❤️",
    "Eres mi lugar favorito, incluso desde lejos. 🥹"
];

// Texto de introducción
const historia = `

Hola, Natasha. ❤️

Este pequeño rincón fue creado especialmente para ti.

Cada pantalla, cada detalle y cada palabra fueron hechos pensando en nosotros.

Quiero que este juego te recuerde cuánto significas para mí.

Y quiero verte para vivir los mejores días de mi vida contigo.

Espero que ese momento llegue muy pronto.

Comencemos nuestra historia...

`;

const frase = document.getElementById("frase");
const btnComenzar = document.getElementById("btnComenzar");
const inicio = document.getElementById("inicio");
const intro = document.getElementById("intro");
const textoIntro = document.getElementById("textoIntro");

// Mostrar frase aleatoria
frase.innerHTML = `"${frases[Math.floor(Math.random() * frases.length)]}"`;

// Corazones flotando
function crearCorazon(){

    const corazon = document.createElement("div");

    corazon.classList.add("heart");

    corazon.innerHTML = "❤️";

    corazon.style.left = Math.random() * 100 + "%";

    corazon.style.animationDuration = (6 + Math.random() * 5) + "s";

    corazon.style.fontSize = (15 + Math.random() * 25) + "px";

    document.getElementById("hearts").appendChild(corazon);

    setTimeout(() => {
        corazon.remove();
    }, 12000);

}

setInterval(crearCorazon, 400);

// Botón comenzar 
btnComenzar.addEventListener("click", ()=>{
const musica = document.getElementById("musica");

btnComenzar.addEventListener("click", () => {

    musica.play();

    inicio.style.display = "none";
    intro.style.display = "flex";

    escribirTexto(historia);

});
    inicio.style.display="none";

    intro.style.display="flex";

    escribirTexto(historia);

});

// Efecto máquina de escribir
function escribirTexto(texto){

    textoIntro.innerHTML="";

    let i=0;

    const velocidad=35;

    function escribir(){

        if(i<texto.length){

            textoIntro.innerHTML+=texto.charAt(i);

            i++;

            setTimeout(escribir,velocidad);

        }

    }

    escribir();

}

// Botón continuar
document.getElementById("continuar").addEventListener("click",()=>{

    alert("💖 Aquí comenzará el Capítulo 1: Nuestra Historia. Lo construiremos en el siguiente paso.");

});
